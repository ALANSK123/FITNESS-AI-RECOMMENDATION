# --- Database Configuration ---
POSTGRES_DB=microservices_db
POSTGRES_USER=user
POSTGRES_PASSWORD=replace_with_secure_password

# --- Keycloak Configuration ---
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=replace_with_secure_password

# --- Server Configuration ---
# Set these if you want to use custom hostnames for internal services
# Usually the container names in docker-compose.prod.yml are sufficient

# --- GitHub Actions Secrets ---
# You'll need these in your repository secrets:
# DOCKER_HUB_USERNAME
# DOCKER_HUB_TOKEN
# VPS_IP
# VPS_USERNAME
# VPS_SSH_KEY
